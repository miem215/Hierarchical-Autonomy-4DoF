<mujoco model="3dof_arm">
    <worldbody>
        <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1"/>
        <body name="base" pos="0 0 0">
            <geom type="cylinder" size="0.1 0.2" rgba="0 1 0 1"/>
            <body name="link1" pos="0 0 0.2">
                <joint name="joint1" type="hinge" axis="0 0 1"/>
                <geom type="capsule" size="0.05 0.5" pos="0 0 0.5" rgba="1 0 0 1"/>
                <body name="link2" pos="0 0 1">
                    <joint name="joint2" type="hinge" axis="0 1 0"/>
                    <geom type="capsule" size="0.05 0.5" pos="0 0 0.5" rgba="0 0 1 1"/>
                    <body name="link3" pos="0 0 1">
                        <joint name="joint3" type="hinge" axis="0 1 0"/>
                        <geom type="capsule" size="0.05 0.5" pos="0 0 0.5" rgba="1 1 0 1"/>
			<body name="link4" pos="0 0 1">
                        	<joint name="joint4" type="hinge" axis="0 1 0"/>
                        	<geom type="capsule" size="0.05 0.5" pos="0 0 0.5" rgba="1 0 1 1"/>
				<site name="end_effector" pos="0 0 1" type="sphere" size="0.05" rgba="0 0 0 1"/>
			</body>
                    </body>
                </body>
            </body>
        </body>
	<body name="obstacle" pos="1.2 0.0 0.5" mocap="true">
            <geom type="cylinder" size="0.1 0.4" rgba="0.5 0.5 0.5 1"/>
        </body>

        <body name="target" pos="1.8 0.0 0.5">
            <geom type="cylinder" size="0.05 0.05" rgba="0 1 0 1" contype="0" conaffinity="0"/>
        </body>
    </worldbody>
	
    <actuator>
        <motor joint="joint1" name="motor1" ctrlrange="-500 500" ctrllimited="true"/>
        <motor joint="joint2" name="motor2" ctrlrange="-500 500" ctrllimited="true"/>
        <motor joint="joint3" name="motor3" ctrlrange="-500 500" ctrllimited="true"/>
	<motor joint="joint4" name="motor4" ctrlrange="-500 500" ctrllimited="true"/>

    </actuator>

    <sensor>
        <jointpos joint="joint1" name="enc_pos_j1"/>
        <jointpos joint="joint2" name="enc_pos_j2"/>
        <jointpos joint="joint3" name="enc_pos_j3"/>
        <jointpos joint="joint4" name="enc_pos_j4"/>

        <jointvel joint="joint1" name="enc_vel_j1"/>
        <jointvel joint="joint2" name="enc_vel_j2"/>
	<jointvel joint="joint3" name="enc_vel_j3"/>
        <jointvel joint="joint4" name="enc_vel_j4"/>
    </sensor>


    <keyframe>
        <key name="home_bent" qpos="0.1 0.1 0.1" />
    </keyframe>
</mujoco>